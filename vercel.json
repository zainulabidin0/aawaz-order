{
  "buildCommand": "npm run setup && npm run build",
  "outputDirectory": "build/client",
  "functions": {
    "api/index.js": {
      "includeFiles": "{build/server/**,node_modules/.prisma/**}",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!assets/|voice-widget\\.js|favicon\\.ico).*)",
      "destination": "/api/index"
    }
  ]
}
