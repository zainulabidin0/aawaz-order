# Shopify App credentials (get from Shopify Partners dashboard)
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
SHOPIFY_APP_URL=https://your-app.fly.dev
SCOPES=read_products,write_orders,read_orders,write_draft_orders,read_draft_orders,read_customers,write_customers

# OpenAI (get from platform.openai.com)
OPENAI_API_KEY=sk-...

# Database — PostgreSQL (Vercel Postgres / Neon / Supabase)
# Vercel auto-populates DATABASE_URL and DIRECT_URL when you add a Postgres store
DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"

# Review Analysis Python service (deploy review-analysis/ on Render)
REVIEW_ANALYSIS_SERVICE_URL=https://aawaz-review-analysis.onrender.com
